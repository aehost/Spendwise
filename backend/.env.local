# ── SpendWise Backend — Local Development ─────────────────────
# Copy this to each service folder as .env for local dev (no Docker)

DATABASE_URL=postgresql://postgres:SpendWise@Dev2025@localhost:5432/spendwise
JWT_ACCESS_SECRET=spendwise_access_jwt_secret_min32chars_2025!
JWT_REFRESH_SECRET=spendwise_refresh_jwt_secret_min32chars_2025!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d
NODE_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# API Gateway only
AUTH_SERVICE_URL=http://localhost:3001
TRANSACTION_SERVICE_URL=http://localhost:3002
USER_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
