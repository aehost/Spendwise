# ── Supabase / PostgreSQL ─────────────────────────────────────
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
DB_SSL=true

# ── JWT (must match api-gateway and auth-service) ─────────────
JWT_ACCESS_SECRET=replace_with_a_long_random_secret_min_32_chars

# ── CORS (internal service — gateway is the only caller) ──────
CORS_ORIGINS=*

# ── Server ────────────────────────────────────────────────────
PORT=3003
NODE_ENV=production
